# Copy to .env and fill in. .env is gitignored.
EXPO_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=sb_publishable_xxx           # or the legacy anon key
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx          # dashboard.clerk.com

# Dev-only: route reel resolution through the local stealth-browser service
# (scripts/local-resolver) instead of the resolve-reel edge function, which
# YouTube bot-walls from Supabase's datacenter IP. Leave unset in prod.
#   iOS simulator:     http://localhost:8787
#   Android emulator:  http://10.0.2.2:8787
#   physical device:   http://<your-mac-LAN-ip>:8787
# EXPO_PUBLIC_LOCAL_RESOLVER_URL=http://localhost:8787
