{
  "name": "onetake",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "expo": {
    "autolinking": {
      "exclude": [
        "expo-apple-authentication"
      ]
    }
  },
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "resolver": "node scripts/local-resolver/server.mjs"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg)"
    ]
  },
  "dependencies": {
    "@clerk/expo": "^3.2.14",
    "@expo-google-fonts/bricolage-grotesque": "^0.4.1",
    "@expo-google-fonts/geist-mono": "^0.4.2",
    "@expo-google-fonts/outfit": "^0.4.3",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.106.0",
    "base64-arraybuffer": "^1.0.2",
    "expo": "~54.0.35",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-auth-session": "~7.0.11",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-frame-extractor": "file:./modules/expo-frame-extractor",
    "expo-glass-effect": "~0.1.10",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-local-authentication": "~17.0.8",
    "expo-media-library": "~18.2.1",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-video": "~3.0.16",
    "expo-web-browser": "~15.0.11",
    "openai": "^6.39.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "typescript": "~5.9.2"
  },
  "private": true
}
