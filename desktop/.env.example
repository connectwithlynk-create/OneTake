# Copy to .env and fill in your keys.
# .env is gitignored — your keys never get committed.

# Used by scripts/fingerprint-eval.ts for hook clustering.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Optional: where the analyzer looks for ONNX models. Defaults to
# desktop/resources/models/ when you run scripts from desktop/.
# SYNCNET_MODEL_DIR=resources/models
